[Unit]
Description=AEMO Negative Prices monthly update
Documentation=https://github.com/cutout-z/aemo-negative-prices
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=aemo
Group=aemo
WorkingDirectory=/opt/aemo-negative-prices
EnvironmentFile=-/etc/aemo-negative-prices/env
ExecStart=/opt/aemo-negative-prices/deploy/run-vps-update.sh
TimeoutStartSec=2h
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=6

StandardOutput=journal
StandardError=journal
